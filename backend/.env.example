# ======================== DATABASE ========================
# MySQL Connection String for Prisma
# Format: mysql://username:password@host:port/database?schema=public
DATABASE_URL=mysql://root:password@localhost:3306/flashsale_db

# ======================== SERVER ========================
# Server port
PORT=3000

# Environment: development, staging, production
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# ======================== JWT AUTHENTICATION ========================
# Secret key for signing JWT tokens
# IMPORTANT: Change this to a strong random string in production
JWT_SECRET=your_super_secret_jwt_key_change_in_production_min_32_chars

# Token expiration time (e.g., 7d, 24h, 1800s)
JWT_EXPIRY=7d

# ======================== REDIS ========================
# Redis connection settings (for caching, sessions, pub/sub)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Optional: Redis database number
REDIS_DB=0

# ======================== SOCKET.IO ========================
# CORS origins for WebSocket connections
SOCKET_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ======================== LOGGING ========================
# Log level: debug, info, warn, error
LOG_LEVEL=info

# ======================== SECURITY ========================
# Bcrypt rounds for password hashing (higher = more secure but slower)
BCRYPT_ROUNDS=10

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ======================== FILE UPLOAD ========================
# Max file size for uploads (in MB)
MAX_FILE_SIZE=5

# Upload directory
UPLOAD_DIR=./uploads

# ======================== EMAIL (Optional) ========================
# SMTP email configuration for sending emails (OTP, order confirmation, etc.)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# ======================== PAYMENT GATEWAY (Optional) ========================
# Integration with payment services
STRIPE_SECRET_KEY=sk_test_xxxxx
PAYPAL_CLIENT_ID=xxxxx
PAYPAL_CLIENT_SECRET=xxxxx

# PayOS Configuration
PAYOS_CLIENT_ID=xxxxx
PAYOS_API_KEY=xxxxx
PAYOS_CHECKSUM_KEY=xxxxx

# ======================== ADMIN ========================
# Default admin credentials (for seeding database)
ADMIN_EMAIL=admin@flashsale.com
ADMIN_PASSWORD=Admin123!@#
