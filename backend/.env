# =======================================================
# File: backend/.env
# Mục đích: Chứa các biến cấu hình nhạy cảm
#   KHÔNG commit file này lên Git! (thêm vào .gitignore)
#   Mỗi máy/môi trường có file .env riêng
# =======================================================

# Môi trường chạy: development hoặc production
NODE_ENV=development

# Cổng server Node.js lắng nghe
PORT=3000

# ===== KẾT NỐI DATABASE MySQL =====
# Format: mysql://user:password@host:port/database
DATABASE_URL="mysql://root:password@localhost:3306/flashsale_db"

# ===== KẾT NỐI REDIS =====
# Format: redis://host:port
REDIS_URL="redis://localhost:6379"

# ===== JWT SECRET =====
# Chuỗi bí mật để ký JWT Token
# QUAN TRỌNG: Đổi thành chuỗi ngẫu nhiên dài trong production!
# Tạo chuỗi ngẫu nhiên: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="your_super_secret_jwt_key_change_this_in_production"

# Thời gian hết hạn Token: 7d = 7 ngày, 1h = 1 giờ, 30m = 30 phút
JWT_EXPIRES_IN="7d"

# ===== FRONTEND URL =====
# Địa chỉ frontend để cấu hình CORS và Socket.io
FRONTEND_URL="http://localhost:5173"
