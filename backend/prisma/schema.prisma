// ============================================
// PRISMA SCHEMA - FLASH SALE E-COMMERCE
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============================================
// 1. USER
// ============================================
model User {
  id          Int      @id @default(autoincrement())
  email       String   @unique @db.VarChar(255)
  password    String   @db.VarChar(255)
  name        String   @db.VarChar(255)
  phone       String?  @db.VarChar(20)
  address     String?  @db.Text
  role        String   @default("user") @db.VarChar(20)

  orders      Order[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  passwordResetToken   String?
  passwordResetExpires DateTime?

  @@index([email])
}

// ============================================
// 2. CATEGORY
// ============================================
model Category {
  id        Int      @id @default(autoincrement())
  name      String   @unique @db.VarChar(100)

  products  Product[]

  createdAt DateTime @default(now())
}

// ============================================
// 3. PRODUCT
// ============================================
model Product {
  id              Int       @id @default(autoincrement())
  name            String    @db.VarChar(255)
  description     String?   @db.Text

  // Pricing
  price           Float
  originalPrice   Float?
  discount        Float     @default(0)

  // UI data
  rating          Float     @default(0)
  sold            Int       @default(0)
  location        String?   @db.VarChar(255)

  // Media
  image           String?   @db.VarChar(500)

  // Category
  categoryId      Int
  category        Category  @relation(fields: [categoryId], references: [id])

  // Stock
  stock           Int       @default(0)
  minimumStock    Int       @default(10)

  // Flash sale flags
  isFlashSale     Boolean   @default(false)
  flashSaleStart  DateTime?
  flashSaleEnd    DateTime?

  // Relations
  inventory       Inventory?
  orderItems      OrderItem[]
  flashSales      FlashSale[]
  reviews         Review[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([categoryId])
  @@index([discount])
  @@index([sold])
  @@index([rating])
}

// ============================================
// 4. INVENTORY
// ============================================
model Inventory {
  id              Int       @id @default(autoincrement())
  productId       Int       @unique

  availableStock  Int       @default(0)
  reservedStock   Int       @default(0)
  damagedStock    Int       @default(0)

  lastStockCheck  DateTime?
  nextStockCheck  DateTime?

  product         Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  movements       InventoryMovement[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// ============================================
// 5. INVENTORY MOVEMENT
// ============================================
model InventoryMovement {
  id          Int       @id @default(autoincrement())
  inventoryId Int

  type        String    @db.VarChar(50) // IN, OUT, ADJUST
  quantity    Int
  reason      String?   @db.VarChar(255)
  reference   String?   @db.VarChar(100)

  inventory   Inventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)

  createdBy   Int?
  createdAt   DateTime  @default(now())

  @@index([inventoryId])
}

// ============================================
// 6. ORDER
// ============================================
model Order {
  id              Int       @id @default(autoincrement())
  userId          Int

  orderNumber     String    @unique @db.VarChar(50)

  totalPrice      Float
  discountAmount  Float     @default(0)
  finalPrice      Float

  status          String    @default("pending") @db.VarChar(50)
  paymentStatus   String    @default("unpaid") @db.VarChar(50)
  shippingStatus  String    @default("pending") @db.VarChar(50)

  shippingAddress String?   @db.Text
  trackingNumber  String?   @db.VarChar(100)

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  items           OrderItem[]
  payments        Payment[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([userId])
  @@index([status])
}

// ============================================
// 7. ORDER ITEM
// ============================================
model OrderItem {
  id          Int     @id @default(autoincrement())
  orderId     Int
  productId   Int

  quantity    Int
  unitPrice   Float
  discount    Float   @default(0)
  subtotal    Float

  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product @relation(fields: [productId], references: [id])

  createdAt   DateTime @default(now())

  @@index([orderId])
  @@index([productId])
}

// ============================================
// 8. PAYMENT
// ============================================
model Payment {
  id            Int     @id @default(autoincrement())
  orderId       Int

  amount        Float
  method        String  @db.VarChar(50)
  transactionId String? @unique @db.VarChar(100)

  status        String  @default("pending") @db.VarChar(50)

  order         Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)

  paidAt        DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([orderId])
}

// ============================================
// 9. FLASH SALE (THEO PRODUCT)
// ============================================
model FlashSale {
  id          Int       @id @default(autoincrement())
  productId   Int

  discount    Float
  quantity    Int

  startTime   DateTime
  endTime     DateTime

  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt   DateTime  @default(now())

  @@index([productId])
  @@index([startTime])
}

// ============================================
// 10. REVIEW (RATING THẬT)
// ============================================
model Review {
  id        Int      @id @default(autoincrement())
  userId    Int
  productId Int

  rating    Float
  comment   String?  @db.Text

  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([productId])
}

// ============================================
// 11. AUDIT LOG
// ============================================
model AuditLog {
  id          Int      @id @default(autoincrement())

  action      String   @db.VarChar(100)
  entity      String   @db.VarChar(50)
  entityId    Int

  userId      Int?

  oldValue    Json?
  newValue    Json?

  ipAddress   String?  @db.VarChar(50)

  createdAt   DateTime @default(now())

  @@index([action])
  @@index([entityId])
}