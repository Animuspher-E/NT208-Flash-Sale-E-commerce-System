// prisma/schema.prisma
// Database Schema cho Flash Sale E-commerce Platform
// Quản lý Users, Products, Inventory, Orders

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============================================
// 1. USER MODEL - Quản lý người dùng
// ============================================
model User {
  id              Int       @id @default(autoincrement())
  email           String    @unique @db.VarChar(255)
  password        String    @db.VarChar(255) // Bcrypt hash
  name            String    @db.VarChar(255)
  phone           String?   @db.VarChar(20)
  address         String?   @db.Text
  
  // Relations
  orders          Order[]
  
  // Audit
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  @@index([email])
  @@index([createdAt])
}

// ============================================
// 2. PRODUCT MODEL - Quản lý sản phẩm
// ============================================
model Product {
  id              Int       @id @default(autoincrement())
  name            String    @db.VarChar(255)
  description     String?   @db.Text
  price           Float     @db.Float
  originalPrice   Float?    @db.Float // Giá gốc trước giảm
  image           String?   @db.VarChar(500)
  sku             String?   @unique @db.VarChar(100)
  
  // Stock tracking
  stock           Int       @default(0) // Tồn kho thực
  minimumStock    Int       @default(10) // Cảnh báo
  
  // Status
  isActive        Boolean   @default(true)
  isFlashSale     Boolean   @default(false)
  flashSaleStart  DateTime?
  flashSaleEnd    DateTime?
  
  // Relations
  inventory       Inventory?
  orderItems      OrderItem[]
  
  // Audit
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  @@index([isFlashSale])
  @@index([flashSaleStart])
  @@index([createdAt])
}

// ============================================
// 3. INVENTORY MODEL - Quản lý tồn kho chi tiết
// ============================================
model Inventory {
  id              Int       @id @default(autoincrement())
  productId       Int       @unique
  
  // Stock levels
  availableStock  Int       @default(0) // Hàng còn bán được
  reservedStock   Int       @default(0) // Đã bán nhưng chưa xác nhận
  damagedStock    Int       @default(0) // Hỏng
  
  // Tracking
  lastStockCheck  DateTime?
  nextStockCheck  DateTime?
  
  // Relations
  product         Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  movements       InventoryMovement[]
  
  // Audit
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([productId])
}

// ============================================
// 4. INVENTORY MOVEMENT - Lịch sử thay đổi kho
// ============================================
model InventoryMovement {
  id              Int       @id @default(autoincrement())
  inventoryId     Int
  
  // Movement details
  type            String    @db.VarChar(50) // "IN", "OUT", "ADJUST", "RETURN"
  quantity        Int
  reason          String?   @db.VarChar(255)
  reference       String?   @db.VarChar(100) // Order ID hoặc reference
  
  // Relations
  inventory       Inventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  
  // Audit
  createdBy       Int?
  createdAt       DateTime  @default(now())

  @@index([inventoryId])
  @@index([createdAt])
}

// ============================================
// 5. ORDER MODEL - Quản lý đơn hàng
// ============================================
model Order {
  id              Int       @id @default(autoincrement())
  userId          Int
  
  // Order info
  orderNumber     String    @unique @db.VarChar(50)
  totalPrice      Float
  discountAmount  Float?    @default(0)
  finalPrice      Float
  
  // Status workflow: pending → confirmed → paid → shipped → delivered → completed
  status          String    @default("pending") @db.VarChar(50)
  paymentStatus   String    @default("unpaid") @db.VarChar(50) // paid, unpaid, refunded
  shippingStatus  String    @default("pending") @db.VarChar(50) // pending, shipped, delivered
  
  // Shipping
  shippingAddress String?   @db.Text
  trackingNumber  String?   @db.VarChar(100)
  estimatedDelivery DateTime?
  
  // Relations
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  items           OrderItem[]
  payments        Payment[]
  
  // Audit
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  cancelledAt     DateTime?

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([orderNumber])
}

// ============================================
// 6. ORDER ITEM MODEL - Chi tiết các sản phẩm trong đơn
// ============================================
model OrderItem {
  id              Int       @id @default(autoincrement())
  orderId         Int
  productId       Int
  
  // Item details
  quantity        Int
  unitPrice       Float     // Giá tại thời điểm đặt hàng
  subtotal        Float     // quantity * unitPrice
  
  // Discount
  discountPercent Float?    @default(0)
  discountAmount  Float?    @default(0)
  
  // Relations
  order           Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product         Product   @relation(fields: [productId], references: [id])
  
  // Audit
  createdAt       DateTime  @default(now())

  @@index([orderId])
  @@index([productId])
}

// ============================================
// 7. PAYMENT MODEL - Quản lý thanh toán
// ============================================
model Payment {
  id              Int       @id @default(autoincrement())
  orderId         Int
  
  // Payment details
  amount          Float
  method          String    @db.VarChar(50) // "credit_card", "bank_transfer", "e_wallet"
  transactionId   String?   @unique @db.VarChar(100)
  
  // Status
  status          String    @default("pending") @db.VarChar(50) // pending, completed, failed, refunded
  
  // Relations
  order           Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  // Audit
  paidAt          DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([orderId])
  @@index([status])
}

// ============================================
// 8. FLASH SALE CONFIG - Cấu hình flash sale
// ============================================
model FlashSale {
  id              Int       @id @default(autoincrement())
  
  // Event details
  name            String    @db.VarChar(255)
  description     String?   @db.Text
  
  // Schedule
  startTime       DateTime
  endTime         DateTime
  
  // Config
  isActive        Boolean   @default(true)
  maxQuantity     Int       @default(1000) // Tổng số lượng flash sale
  
  // Audit
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([startTime])
  @@index([endTime])
}

// ============================================
// 9. AUDIT LOG - Ghi log tất cả thay đổi quan trọng
// ============================================
model AuditLog {
  id              Int       @id @default(autoincrement())
  
  // What happened
  action          String    @db.VarChar(100) // "CREATE_ORDER", "UPDATE_INVENTORY"
  entity          String    @db.VarChar(50)  // "Order", "Product"
  entityId        Int
  
  // Who did it
  userId          Int?
  
  // Details
  oldValue        Json?   @db.Json
  newValue        Json?   @db.Json
  ipAddress       String?   @db.VarChar(50)
  
  // Audit
  createdAt       DateTime  @default(now())

  @@index([action])
  @@index([entityId])
  @@index([createdAt])
}
